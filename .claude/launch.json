{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Frontend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd frontend && npm run dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Docker Compose (All Services)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up"],
      "port": 80
    }
  ]
}
