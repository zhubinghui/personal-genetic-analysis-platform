# =============================================================
# 个人基因抗衰老分析平台 — 环境变量示例
# 复制为 .env 并填写真实值
# =============================================================

# ---- PostgreSQL ----
POSTGRES_DB=genetic_platform
POSTGRES_USER=app_user
POSTGRES_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql+asyncpg://app_user:changeme_strong_password@postgres:5432/genetic_platform
DATABASE_URL_SYNC=postgresql://app_user:changeme_strong_password@postgres:5432/genetic_platform

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---- MinIO 对象存储 ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_IDAT=idat-raw
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_KNOWLEDGE=knowledge-docs
MINIO_USE_SSL=false

# ---- 文件加密 (AES-256-GCM) ----
# 生成: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
FILE_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_BASE64_ENCODED_KEY=

# ---- JWT 认证 ----
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# ---- 应用 ----
ENVIRONMENT=development
LOG_LEVEL=INFO
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ---- 当前知情同意版本 ----
CONSENT_VERSION=1.0

# ---- Resend 邮件 API ----
# 注册 https://resend.com 获取 API Key（免费 3000 封/月）
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=基因抗衰老分析平台

# ---- 阿里云短信 ----
# 控制台：https://dysms.console.aliyun.com
# 需创建 RAM 用户（仅短信权限）+ 短信签名 + 短信模板（含 ${code} 变量）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=基因分析平台
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxxx

# ---- 验证码 ----
VERIFY_CODE_EXPIRE_MINUTES=10
PASSWORD_RESET_EXPIRE_MINUTES=30

# ---- OAuth 第三方登录 ----
# GitHub: Settings → Developer settings → OAuth Apps → New OAuth App
# Callback URL: http://localhost:8000/api/v1/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google: Google Cloud Console → APIs → Credentials → OAuth 2.0 Client
# Callback URL: http://localhost:8000/api/v1/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 微信：open.weixin.qq.com → 网站应用（需企业认证）
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# OAuth 回调基础 URL（后端地址）
OAUTH_REDIRECT_BASE=http://localhost:8000

# ---- 知识库（本地向量数据库）----
# fastembed 模型缓存路径（容器内路径，挂载为 Docker Volume）
FASTEMBED_CACHE_PATH=/app/.cache/fastembed
# 管理员账号通过数据库直接设置 is_admin=true
# 示例：UPDATE users SET is_admin=true WHERE email='admin@example.com';
